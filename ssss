# 3. 審核結果欄位是否合法（AL欄/38欄）

def check_review_result(ws, col=38):
    print("--> 正在檢查 審核結果欄位（AL欄）是否合法...")
    issues = []
    for r in range(2, ws.max_row + 1):
        val = ws.cell(row=r, column=col).value
        val_str = str(val) if val is not None else ""
        if (val is None or val_str.strip() == "" or
            "'" in val_str or "\n" in val_str or
            val_str != val_str.strip()):
            issues.append((r, val))
    if issues:
        print("下列 AL 欄有異常（空白、單引號、換行、前後空格）：")
        for row, val in issues:
            print(f"  第{row}列，AL欄值：{val}")
    else:
        print("所有 AL 欄資料皆正常。")  
def main():
    args = parse_arguments()
    input_file = args.input_file
    
    if not os.path.exists(input_file):
        print(f"錯誤: 找不到檔案 {input_file}")
        sys.exit(1)

    print(f"--> 開始處理檔案: {input_file}")
    
    # 檢查工作表
    try:
        xl = pd.ExcelFile(input_file)
    except Exception as e:
        print(f"錯誤: 無法讀取 Excel 檔案 ({e})")
        sys.exit(1)
        
    if "Data" not in xl.sheet_names or "Code" not in xl.sheet_names:
        print("錯誤: 檔案必須包含 'Data' 和 'Code' 工作表")
        sys.exit(1)

    # 使用 openpyxl 載入
    wb = load_workbook(input_file)
    ws = wb["Data"]

    # === 執行步驟 ===
    unify_font_color(ws)
    set_customer_no_as_text(ws, customer_col=5)
    check_duplicate_customer_no(ws, customer_col=5)

    # check_jobtitle_code
    ws_code = wb["Code"]
    check_jobtitle_code(ws, ws_code, jobtitle_col=29, code_col=3)


    check_occup_code(ws, ws_code, occup_col=28, code_col=2)


    check_birth_country_code(ws, ws_code, col_data=25, col_code=1)
    check_permanent_country_code(ws, ws_code, col_data=26, col_code=1)
    check_mail_country_code(ws, ws_code, col_data=27, col_code=1)

    check_employer_filter(ws, col=30)
    check_account_purpose_code(ws, ws_code, col_data=36, col_code=4)
    check_review_result(ws, col=38)

    # # 儲存結果
