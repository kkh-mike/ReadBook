# 1. 任職機構篩選輔助欄（AD欄/30欄）

def check_employer_filter(ws, col=30):
    print("--> 正在檢查 任職機構篩選輔助欄（AD欄）...")
    issues = []
    for r in range(2, ws.max_row + 1):
        cell = ws.cell(row=r, column=col)
        val = str(cell.value).strip() if cell.value is not None else ""
        color = cell.font.color.rgb if cell.font and cell.font.color else None
        if val == "" or "'" in val or "\n" in val or (color and color.upper() != "000000"):
            issues.append((r, val, color))
    if issues:
        print("下列 AD 欄有異常（空白、單引號、換行、非黑字）：")
        for row, val, color in issues:
            print(f"  第{row}列，AD欄值：{val}，顏色：{color}")
    else:
        print("所有 AD 欄資料皆正常。")


