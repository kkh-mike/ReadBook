import os
import sys
import argparse
import pandas as pd
from openpyxl import load_workbook
from openpyxl.styles import Font, NamedStyle
from openpyxl.utils import get_column_letter

def parse_arguments():
    """解析命令列參數"""
    parser = argparse.ArgumentParser(description="Data 頁面資料純邏輯檢核工具（輸出 Log）")
    parser.add_argument("input_file", help="輸入的 Excel 檔案路徑 (例如: data.xlsx)")
    return parser.parse_args()


def unify_font_color(ws):
    """全資料區字體顏色統一：除了正紅字外，其他全部改成黑色"""
    print("--> 正在統一字體顏色（保留正紅字）...")
    black_font = Font(color="000000")
    
    max_row = ws.max_row
    max_col = ws.max_column
    
    for row in range(4, max_row + 1):
        for col in range(1, max_col + 1):
            cell = ws.cell(row=row, column=col)
            if cell.font and cell.font.color and str(cell.font.color.rgb).upper() in ["FFFF0000", "FF0000"]:
                continue  # 保留正紅字
            cell.font = black_font


def set_customer_no_as_text(ws, customer_col=5):
    """將 CustomerNo 欄位設為文字格式"""
    print(f"--> 正在將 E 欄 (CustomerNo) 設為文字格式...")
    text_style = NamedStyle(name="text_format")
    text_style.number_format = '@'
    
    for row in range(1, ws.max_row + 1):
        cell = ws.cell(row=row, column=customer_col)
        cell.style = text_style


def check_duplicate_customer_no(ws, customer_col=5):
    print("--> 正在檢查 E 欄 CustomerNo 重複...")

    last_row = ws.max_row
    if last_row < 2:
        print("    資料列不足，跳過重複檢查")
        return

    values = []
    empty_count = 0
    for r in range(2, last_row + 1):  # 從第2列開始
        val = ws.cell(row=r, column=customer_col).value
        key = str(val).strip() if val is not None else ""
        values.append(key)
        if key == "":
            empty_count += 1

    from collections import Counter
    customer_count = Counter([v for v in values if v])

    print("所有 CustomerNo 出現次數：")
    for k, v in customer_count.items():
        print(f"{k}: {v}")

    duplicates = {k: v for k, v in customer_count.items() if v > 1}
    print(f"總共檢查了 {len(values)} 筆 CustomerNo")
    print(f"其中空值有 {empty_count} 筆")
    if duplicates:
        print("重複的 CustomerNo：")
        for k, v in duplicates.items():
            print(f"  {k}：{v} 次")
    else:
        print("沒有重複的 CustomerNo")

def check_jobtitle_code(ws_data, ws_code, jobtitle_col=29, code_col=3):
    print("--> 正在檢查 JobTitle 代碼是否存在於 Code 工作表...")

    # 取得 Code 工作表所有 C 欄的代碼（只取前四碼）
    code_set = set()
    for r in range(2, ws_code.max_row + 1):
        val = ws_code.cell(row=r, column=code_col).value
        if val:
            code_set.add(str(val).strip())

    # 檢查 Data 工作表 AC 欄
    not_found = []
    for r in range(2, ws_data.max_row + 1):
        val = ws_data.cell(row=r, column=jobtitle_col).value
        if val:
            code4 = str(val).strip()[:4]
            if code4 and code4 not in code_set:
                not_found.append((r, val, code4))

    if not_found:
        print("下列 JobTitle 代碼前四碼不存在於 Code 工作表 C 欄：")
        for row, full_val, code4 in not_found:
            print(f"  第{row}列，AC欄值：{full_val}，前四碼：{code4}")
    else:
        print("所有 JobTitle 代碼前四碼都存在於 Code 工作表。")


