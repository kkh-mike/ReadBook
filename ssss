import os
import sys
import argparse
import pandas as pd
from openpyxl import load_workbook

def parse_arguments():
    """解析命令列參數"""
    parser = argparse.ArgumentParser(description="Data 頁面資料純邏輯檢核工具（輸出 Log）")
    parser.add_argument("input_file", help="輸入的 Excel 檔案路徑 (例如: data.xlsx)")
    return parser.parse_args()

def main():
    args = parse_arguments()
    input_file = args.input_file
    
    if not os.path.exists(input_file):
        print(f"錯誤: 找不到檔案 {input_file}")
        sys.exit(1)

    print(f"--> 開始讀取檔案: {input_file}")
    
    # 1. 檢查工作表是否存在
    try:
        xl = pd.ExcelFile(input_file)
    except Exception as e:
        print(f"錯誤: 無法讀取 Excel 檔案 ({e})")
        sys.exit(1)
        
    if "Data" not in xl.sheet_names or "Code" not in xl.sheet_names:
        print("錯誤: 檔案必須包含 'Data' 工作表")
        sys.exit(1)


if __name__ == "__main__":
    main()




