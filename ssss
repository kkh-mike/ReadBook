SELECT
'PART1' Report, 
B.CUST_TYPE_CDE AS '客戶類型',
B.CUSTOMER_SEGMENT AS '客戶群體',
'_'+ D.CUSTOMERNO AS 'CUSTOMERNO',
'_' + ISNULL(A.QUEUENAME,'') AS 'RM_工作群組',
B.CUST_NME AS '姓名1',
B.NATIVE_CUST_NME AS '姓名2',
'_'+ B.BRNCH_NBR AS '所屬分行',
CONVERT(CHAR(8),E.ReviewDt,112) 下次審核日期,
D.HIGHRISK 風險等級,
D.RISKSCORE 風險分數,
F.PEP as PEP,
F.ForeignPEP AS ForeignPEP,
F.LocalPEP AS LocalPEP,
F.ForeignOrgPEP AS ForeignOrgPEP,
F.ExPEP AS ExPEP,
F.CustRPIsPEP AS RCA,
F.BlackList AS BlackList,
F.NN as NegativeNews,
CONVERT(CHAR(8),B.OPEN_DTE,112) 開戶日期,ISNULL(B.NATIONALITY_1,'') NATIONALITY,
CASE WHEN B.CUST_TYPE_CDE ='P' THEN D.OCCUP + '_' + RTRIM(G.OCCUPDESC) ELSE '' END OCCUP,
ISNULL(B.NAICS_CDE,'')  + '_' + RTRIM(I.Description) '行業別',
--ISNULL(J.INVST_AMT,0) AS AUM,
--CASE WHEN K.CUST_ID IS NULL THEN 'N' ELSE 'Y' END '是否久未往來(超過12個月)',
b.RecordStatus 客戶狀態, 
CASE WHEN ISNULL(D.OBUFlag,'') <>'Y' THEN 'N' ELSE D.OBUFlag END OBUFlag, D.CoreSystem 系統來源, B.REM_CDE 'AO_CODE', B.REM_NME 'AO_NAME'
FROM BSADBHK..PB_CUSTOMER_FACT B WITH (NOLOCK)
LEFT JOIN
(
SELECT A.BATCHID,A.CIF_KEY,A.STATUS,B.QUEUENAME FROM  BSADBHK..HRS_CUST_RISK_MGMT A WITH (NOLOCK)
INNER JOIN BSADBHK..WORKFLOW_MGMT_QUEUE B WITH (NOLOCK) ON A.QUEUEID = B.QUEUEID
WHERE STATUS <> '3' AND SRC ='HRS' 
) A ON B.CIF_KEY = A.CIF_KEY
JOIN BSADBHK..BSA_SUB_CUST_FACT D WITH (NOLOCK) ON B.CIF_KEY = D.CIF_KEY
LEFT JOIN (
  SELECT C.CIFKEY,C.ReviewDt FROM BSADBHK..EDD_ReviewSchedule C WITH (NOLOCK) 
  INNER JOIN (
      SELECT CIFKEY,MIN(ReviewDt) ReviewDt FROM BSADBHK..EDD_ReviewSchedule WITH (NOLOCK) WHERE STATUS ='P'
      GROUP BY CIFKEY) C2 ON C.CIFKey = C2.CIFKey  AND C.ReviewDt = C2.ReviewDt
 )  E ON B.CIF_KEY = E.CIFKEY
LEFT JOIN (
SELECT CIF_KEY,IsBearerShares,
CASE WHEN PEPBitwiseCode & 1=1 THEN 'Y' ELSE 'N' END BlackList,
CASE WHEN PEPBitwiseCode & 2=2 THEN 'Y' ELSE 'N' END PEP,
CASE WHEN PEPBitwiseCode & 8=8 THEN 'Y' ELSE 'N' END ForeignPEP,
CASE WHEN PEPBitwiseCode & 16=16 THEN 'Y' ELSE 'N' END LocalPEP,
CASE WHEN PEPBitwiseCode & 32=32 THEN 'Y' ELSE 'N' END ForeignOrgPEP,
CASE WHEN PEPBitwiseCode & 64=64 THEN 'Y' ELSE 'N' END ExPEP,
CASE WHEN PEPBitwiseCode & 128=128 THEN 'Y' ELSE 'N' END CustRPIsPEP ,
CASE WHEN PEPBitwiseCode & 4=4 THEN 'Y' ELSE 'N' END NN
FROM BSADBHK..BSA_SUB_CUST_FACT_Extension
 ) F ON B.CIF_KEY = F.CIF_KEY
 LEFT JOIN BSADBHK..OCCUPATION_DIM G ON D.OCCUP = G.OCCUPCD 
 LEFT JOIN BSADBHK..JobTitle_DIM H ON D.JobTitle = H.ID
 LEFT JOIN BSADBHK..FINCEN_NAICS_DIM I ON B.NAICS_CDE = I.NAICS_Code
 JOIN @CustID J ON D.CustomerNo = J.CustomerNo





